# Example environment values for local stake-mpp workflows.
# Copy to .env (or export manually) and replace placeholders only.

# Deployment / chain access

RPC_URL=https://your-rpc-endpoint
CHAIN_ID=your-chain-id
CAST_ACCOUNT=base-deployer
SENDER_ADDRESS=0x0000000000000000000000000000000000000000
WHITELISTED_TOKENS=0x0000000000000000000000000000000000000000,0x1111111111111111111111111111111111111111

# Local server
MPP_SECRET_KEY=replace-with-a-long-random-string
HOST=127.0.0.1
PORT=4020

# Optional CLI defaults
MPP_RESOURCE_URL=http://127.0.0.1:4020/documents/document
MPP_ESCROW_CONTRACT=0x0000000000000000000000000000000000000000
MPP_ESCROW_ACCOUNT=base-deployer
MPP_ESCROW_PASSWORD_FILE=./password.txt

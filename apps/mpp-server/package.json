{
  "name": "@stake-mpp/mpp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=../../.env --experimental-strip-types src/index.ts",
    "prebuild": "npm run build --workspace=@gitbondhq/mppx-stake",
    "build": "tsc -p tsconfig.json",
    "precheck-types": "npm run build --workspace=@gitbondhq/mppx-stake",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . && npm run check-types",
    "test": "npm run check-types"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@gitbondhq/mppx-stake": "file:../../packages/mppx-stake",
    "express": "^5.2.1",
    "mppx": "^0.4.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  }
}

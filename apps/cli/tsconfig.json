{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "dist",
    "noEmitOnError": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}

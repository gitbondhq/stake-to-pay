{
  "name": "@stake-mpp/cli",
  "version": "0.1.0",
  "description": "Command-line interface for the MPPEscrow contract",
  "type": "module",
  "bin": {
    "stake-mpp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prebuild": "npm run build --workspace=@gitbondhq/mppx-stake",
    "build": "tsc -p tsconfig.json",
    "precheck-types": "npm run build --workspace=@gitbondhq/mppx-stake",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint . && npm run check-types",
    "test": "npm run check-types"
  },
  "keywords": [
    "cli",
    "ethereum",
    "escrow",
    "viem"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@gitbondhq/mppx-stake": "*",
    "commander": "^13.1.0",
    "ox": "^0.14.10",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@gitbondhq/mppx-escrow",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./tempo": {
      "types": "./dist/tempo/index.d.ts",
      "default": "./dist/tempo/index.js"
    },
    "./abi": {
      "types": "./dist/abi/index.d.ts",
      "default": "./dist/abi/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "generate:abi": "forge build --root ../.. && node scripts/generate-abi.mjs",
    "build": "npm run generate:abi && tsc -p tsconfig.json",
    "lint": "eslint . && tsc -p tsconfig.json --noEmit",
    "fix": "eslint . --fix && tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "mppx": "^0.4.11",
    "ox": "^0.14.7",
    "viem": "^2.47.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  }
}

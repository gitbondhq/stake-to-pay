{
  "name": "stake-mpp",
  "private": true,
  "scripts": {
    "build": "npm run build:mppx-escrow && turbo run build",
    "build:mppx-escrow": "npm run generate:abi:mppx-escrow && tsc -p packages/mppx-escrow/tsconfig.json",
    "generate:abi:mppx-escrow": "forge build && node scripts/generate-mpp-escrow-abi.mjs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
